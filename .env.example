# =============================================================================
# DTSG ERP — Environment Configuration
# =============================================================================
# Copy to .env and customize for your environment.
# IMPORTANT: Never commit .env to version control!

# Core (REQUIRED)
SECRET_KEY=generate_a_new_secure_key_here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,api.yourdomain.com

# Primary Database (REQUIRED)
DB_NAME=quot_pse
DB_USER=dtsg
DB_PASSWORD=your_secure_database_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# Connection tuning
CONN_MAX_AGE=60

# Phase 1: PgBouncer (optional)
# DB_PORT=6432

# Phase 2: Redis (enables shared caching + Celery broker)
# REDIS_URL=redis://localhost:6379/1

# Phase 2: Celery
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Phase 3: Read Replica (optional)
# DB_REPLICA_HOST=replica-host.example.com
# DB_REPLICA_PORT=5432
# DB_REPLICA_NAME=quot_pse
# DB_REPLICA_USER=dtsg_readonly
# DB_REPLICA_PASSWORD=readonly_password

# Email
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Token expiration
TOKEN_EXPIRATION_HOURS=24

# JWT Configuration
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# JWT_REFRESH_TOKEN_LIFETIME_HOURS=24

# Superadmin creation (optional, for initial setup)
# SUPERADMIN_USERNAME=superadmin
# SUPERADMIN_EMAIL=admin@yourdomain.com
# SUPERADMIN_PASSWORD=your_secure_admin_password_here

# Gunicorn (production)
# GUNICORN_WORKERS=9
# GUNICORN_THREADS=4
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_LOG_LEVEL=info
